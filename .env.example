# ============================================================
# Vehicle Detection Backend - Environment Configuration
# ============================================================
# Copy this file to .env and update values for your environment.

# --- Flask Settings ---
PORT=5000
FLASK_DEBUG=false

# --- API Security ---
# IMPORTANT: Change this to a strong, unique key in production!
API_KEY=change-me-in-production

# --- CORS Allowed Origins (comma-separated) ---
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- RTSP Camera Streams (Dual Camera) ---
# ENTRY gate camera (vehicles coming in)
ENTRY_RTSP_URL=rtsp://tplink-tc65:12345678@192.168.100.81:554/stream1
# EXIT gate camera (vehicles going out)
EXIT_RTSP_URL=rtsp://TC200C:CAMERA-TC200C@192.168.100.84:554/stream2
# Legacy fallback: RTSP_URL is used as ENTRY if ENTRY_RTSP_URL is not set
RTSP_URL=
RTSP_RECONNECT_DELAY_BASE=2
RTSP_RECONNECT_MAX_DELAY=60

# --- Detection Parameters ---
PLATE_COOLDOWN=10
MIN_STAY_DURATION=60
FRAME_SKIP=3
VEHICLE_CONFIDENCE=0.4

# --- Database Configuration ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=vehicle_detection
DB_PORT=3306
DB_POOL_SIZE=5

# --- Cache Settings ---
CACHE_TTL=300

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=backend.log

# --- Ngrok Tunnel (Optional) ---
# Get your free auth token at: https://dashboard.ngrok.com/get-started/your-authtoken
# Required to use: python start_with_ngrok.py
NGROK_AUTH_TOKEN=36ZHbLo13wmXfHt7KoqqhPoN7uf_3vsBdr7VJmcEHK1Q21EDY
